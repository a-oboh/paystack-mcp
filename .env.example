# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paystack_mcp

# ─── Paystack ────────────────────────────────────────────────────────────────
# Used directly in development (bypasses DB lookup)
# Use TEST keys locally — never live keys in dev
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_ENVIRONMENT=test
PAYSTACK_BASE_URL=https://api.paystack.co

# ─── Encryption ──────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting Paystack secret keys at rest
# Must be exactly 32 characters
ENCRYPTION_KEY=change_me_to_a_32_char_secret_key

# ─── MCP ─────────────────────────────────────────────────────────────────────
MCP_TRANSPORT=stdio
