# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=
PORT=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── Paystack ────────────────────────────────────────────────────────────────
# Used directly in development (bypasses DB lookup)
# Use TEST keys locally — never live keys in dev
PAYSTACK_SECRET_KEY=
PAYSTACK_ENVIRONMENT=
PAYSTACK_BASE_URL=

# ─── Encryption ──────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting Paystack secret keys at rest
# Must be exactly 32 characters
ENCRYPTION_KEY=

# ─── MCP ─────────────────────────────────────────────────────────────────────
MCP_TRANSPORT=
